<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <queries>
        <package android:name="com.ea.gp.fifaworld" />
        <package android:name="moe.shizuku.privileged.api" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/dlavie_launcher_icon"
        android:roundIcon="@drawable/dlavie_launcher_icon"
        android:label="@string/app_name"
        android:theme="@style/AppTheme.Splash"
        android:usesCleartextTraffic="false">

        <meta-data
            android:name="moe.shizuku.client.V3_SUPPORT"
            android:value="true" />

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <activity
            android:name=".CommunityActivity"
            android:exported="false" />

        <activity
            android:name=".GameHubActivity"
            android:exported="true"
            android:icon="@drawable/dlavie_launcher_icon"
            android:label="DLavie Updater">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ModernLauncherActivity"
            android:exported="true"
            android:icon="@drawable/dlavie_launcher_icon"
            android:label="DLavie Hub"
            android:theme="@style/AppTheme.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
