<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <queries>
        <package android:name="com.ea.gp.fifaworld" />
        <package android:name="com.ea.game.fifa14_row" />
        <package android:name="moe.shizuku.privileged.api" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.android.package-archive" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/dlavie_launcher_icon"
        android:roundIcon="@mipmap/dlavie_launcher_icon"
        android:label="@string/app_name"
        android:theme="@style/AppTheme.Splash"
        android:debuggable="false"
        android:usesCleartextTraffic="false">

        <meta-data
            android:name="moe.shizuku.client.V3_SUPPORT"
            android:value="true" />

        <!-- Firebase Cloud Messaging — handles push notifications from Dev Dashboard -->
        <service
            android:name=".DLavieFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Firebase Crashlytics — auto-init enabled (crash reporting) -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="true" />

        <!-- Firebase Analytics — auto-init enabled -->
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="true" />

        <!-- Default notification icon for FCM (used when app is in background) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/dlavie_launcher_icon" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/dlavie_accent_cyan" />

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.files"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".CommunityActivity"
            android:exported="false" />




        <activity
            android:name=".ModernLauncherActivity"
            android:exported="false"
            android:label="DLavie 26"
            android:theme="@style/AppTheme.Splash" />

        <!-- Shiny splash screen — true launcher entry point -->
        <activity
            android:name=".ShinySplashActivity"
            android:exported="true"
            android:icon="@mipmap/dlavie_launcher_icon"
            android:label="DLavie 26"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".DLavieGuidedActivity"
            android:exported="true"
            android:icon="@mipmap/dlavie_launcher_icon"
            android:label="DLavie 26"
            android:launchMode="singleTop"
            android:theme="@style/AppTheme.Splash">
            <!-- v6.8.4: Deep link for Google OAuth callback (dlavie://auth-callback) -->
            <!-- Supabase redirects here after Google login with access_token in URL fragment -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="dlavie" android:host="auth-callback" />
            </intent-filter>
        </activity>

        <!-- Internal recovery shell only. Do not expose this as the public launcher entry. -->
        <activity
            android:name=".DevLauncherActivity"
            android:exported="false"
            android:label="DLavie Recovery Console"
            android:theme="@style/AppTheme.Splash" />

        <!-- PIN lock activity (unlock / setup / change / disable) -->
        <activity
            android:name=".PinLockActivity"
            android:exported="false"
            android:label="DLavie PIN"
            android:theme="@style/AppTheme.Splash"
            android:excludeFromRecents="true"
            android:lockTaskMode="if_whitelisted" />
    </application>
</manifest>
