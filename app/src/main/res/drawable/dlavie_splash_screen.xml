<?xml version="1.0" encoding="utf-8"?>
<!-- DLavie v3.0 splash screen drawable (system splash, shown before activity setContent).
     Monochrome near-black bg + subtle white radial glow + new launcher icon. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0A" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="420dp" android:height="420dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="210dp"
                android:startColor="#10FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:width="148dp"
        android:height="148dp"
        android:drawable="@mipmap/dlavie_launcher_icon" />
</layer-list>
